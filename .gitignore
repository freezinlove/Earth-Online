# Bundled geodata database is committed; local build byproducts are ignored.
external/geodata/*.sqlite
!external/geodata/geonames.sqlite
external/geodata/*.sqlite-*
external/geodata/downloads/

# Local source checkout used for reference/debugging. The app uses npm three-globe.
external/three-globe/

# Private design notes and local media fixtures
DESIGN_SPECS/

# OS and editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
