# Dependencies
node_modules/

# Build, cache, and test output
dist/
release/
output/
test-results/
coverage/
.playwright-cli/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment files
.env
.env.*

# Local user data
data/**
!data/
