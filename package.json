{
  "name": "earth-online",
  "description": "Local-first travel photo archive with a 3D Earth timeline.",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "node server/dev.mjs --host 0.0.0.0",
    "frontend": "vite",
    "backend": "node server/index.mjs",
    "generate:globe": "node scripts/generate_globe_assets.mjs",
    "geodata:download": "node scripts/geodata_download.mjs",
    "geodata:build": "node scripts/geodata_build.mjs",
    "geodata:enrich:zh": "node scripts/geodata_enrich_zh_names.mjs --min-population=50000",
    "geodata:clean:zh": "node scripts/geodata_clean_zh_overrides.mjs",
    "geodata:generate:zh": "node scripts/geodata_generate_zh_overrides.mjs --min-population=50000",
    "geodata:setup": "npm run geodata:download && npm run geodata:build",
    "build": "tsc -b && vite build",
    "test:mvp": "node scripts/mvp_acceptance.mjs",
    "test:backend": "node scripts/backend_projection_checks.mjs",
    "test:parity": "node scripts/android_desktop_parity_checks.mjs",
    "data:backup": "node scripts/data_backup.mjs",
    "data:reset": "node scripts/data_reset.mjs",
    "data:rebuild": "node scripts/data_rebuild_from_existing_photos.mjs",
    "seed:demo": "node scripts/seed_demo.mjs",
    "electron:dev": "node electron/dev.mjs",
    "electron:pack": "npm run build && electron-builder --dir && node scripts/electron_patch_icon.mjs",
    "electron:dist": "npm run build && electron-builder --dir && node scripts/electron_patch_icon.mjs && electron-builder --win nsis --x64 --prepackaged release/win-unpacked",
    "electron:smoke": "node scripts/electron_packaged_smoke.mjs",
    "cap:sync": "npm run build && cap sync android",
    "android:build": "npm run cap:sync && cd android && .\\gradlew.bat assembleDebug",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0"
  },
  "build": {
    "appId": "com.earthonline.desktop",
    "productName": "Earth Online",
    "electronDist": "node_modules/electron/dist",
    "electronVersion": "42.0.1",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "docs/gugugaga.png",
      "electron/**/*",
      "server/**/*",
      "shared/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "external/geodata/geonames.sqlite",
        "to": "geodata/geonames.sqlite"
      }
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "docs/gugugaga.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "busboy": "^1.6.0",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "three": "^0.172.0",
    "three-globe": "^2.45.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^9.17.0",
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  }
}
